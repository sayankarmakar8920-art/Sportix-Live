generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  image      String?
  role       String   @default("user")
  isOnline   Boolean  @default(false)
  lastSeen   DateTime @default(now())
  loginCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Stream {
  id             String          @id @default(cuid())
  title          String
  description    String?
  thumbnail      String?
  category       String          @default("football")
  status         String          @default("offline")
  rtmpUrl        String?
  streamKey      String?
  viewerCount    Int             @default(0)
  peakViewers    Int             @default(0)
  fps            Float?
  bitrate        Float?
  isFeatured     Boolean         @default(false)
  homeTeam       String
  awayTeam       String
  homeScore      Int             @default(0)
  awayScore      Int             @default(0)
  matchTime      String?
  startTime      DateTime?
  endedAt        DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  chatMessages   ChatMessage[]
  reactions      Reaction[]
  recordings     Recording[]
  videos         Video[]
  viewerSessions ViewerSession[]
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  thumbnail   String?
  duration    Int      @default(0)
  category    String   @default("highlights")
  views       Int      @default(0)
  videoUrl    String?
  isFeatured  Boolean  @default(false)
  streamId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stream      Stream?  @relation(fields: [streamId], references: [id])
}

model ChatMessage {
  id            String   @id @default(cuid())
  streamId      String
  username      String
  message       String
  isHighlighted Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  createdAt     DateTime @default(now())
  stream        Stream   @relation(fields: [streamId], references: [id])
}

model ContinueWatching {
  id        String   @id @default(cuid())
  videoId   String
  title     String
  thumbnail String?
  duration  Int      @default(0)
  progress  Float    @default(0)
  watchedAt DateTime @default(now())
}

model Ad {
  id            String    @id @default(cuid())
  title         String
  description   String?
  type          String    @default("banner")
  mediaUrl      String
  targetUrl     String?
  category      String?
  duration      Int?
  position      String?
  placement     String?
  deviceTarget  String?
  countryTarget String?
  cpm           Float?
  cpc           Float?
  priority      Int       @default(0)
  isActive      Boolean   @default(true)
  impressions   Int       @default(0)
  clicks        Int       @default(0)
  skipAfter     Int       @default(5)
  scheduleStart DateTime?
  scheduleEnd   DateTime?
  abTestGroup   String?
  midRollTimes  String?
  autoSchedule  Boolean   @default(true)
  adFrequency   String?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AdEvent {
  id        String   @id @default(cuid())
  adId      String
  event     String
  userId    String?
  streamId  String?
  sessionId String?
  metadata  String?
  createdAt DateTime @default(now())
}

model Recording {
  id           String   @id @default(cuid())
  streamId     String
  title        String
  description  String?
  thumbnail    String?
  videoUrl     String
  duration     Int?
  fileSize     Int?
  views        Int      @default(0)
  status       String   @default("processing")
  uploadedToR2 Boolean  @default(false)
  r2Url        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  stream       Stream   @relation(fields: [streamId], references: [id])
}

model Reaction {
  id        String   @id @default(cuid())
  streamId  String
  type      String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stream    Stream   @relation(fields: [streamId], references: [id])
}

model ViewerSession {
  id        String    @id @default(cuid())
  streamId  String
  userId    String?
  sessionId String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  isLive    Boolean   @default(true)
  stream    Stream    @relation(fields: [streamId], references: [id])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  thumbnail   String?
  videoCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdMedia {
  id           String   @id @default(cuid())
  originalName String
  fileName     String
  fileType     String
  mimeType     String
  fileSize     Int
  width        Int?
  height       Int?
  duration     Float?
  thumbnailUrl String?
  hlsReady     Boolean  @default(false)
  status       String   @default("uploading")
  uploadChunks Int      @default(0)
  totalChunks  Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
